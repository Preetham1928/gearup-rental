# ─── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── PostgreSQL (SQL) ─────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=rentforge

# ─── MongoDB (NoSQL) ──────────────────────────
MONGO_URI=mongodb://localhost:27017/rentforge

# ─── Frontend URL (CORS) ──────────────────────
CLIENT_URL=http://localhost:3000
